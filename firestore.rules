rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Instructors self-register — PIN is stored hashed (SHA-256), never plain text
    match /instructors/{instructorId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Sessions (instructor creates/updates session info) and questions
    match /sessions/{sessionId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
      match /questions/{questionId} {
        allow read: if true;
        allow create: if true;
        // Updates keep authorId unchanged (votes, answers, status, student text edits).
        allow update: if resource.data.authorId == request.resource.data.authorId;
        // Instructors delete from the dashboard; without Firebase Auth this cannot be restricted to “only instructors”.
        allow delete: if true;
      }
      // Anonymous student dashboard feedback per session (path implies session; no email stored).
      match /sessionFeedback/{docId} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasAll(['subject', 'body', 'submittedAtMs'])
          && request.resource.data.size() == 3
          && request.resource.data.subject is string
          && request.resource.data.body is string
          && (
            request.resource.data.submittedAtMs is int
            || (
              request.resource.data.submittedAtMs is float
              && int(request.resource.data.submittedAtMs) == request.resource.data.submittedAtMs
            )
          )
          && request.resource.data.submittedAtMs >= 946684800000
          && request.resource.data.submittedAtMs <= 4102444800000
          && request.resource.data.subject.size() > 0
          && request.resource.data.subject.size() <= 500
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 12000;
        allow update, delete: if false;
      }
    }
  }
}
