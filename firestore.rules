rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Instructors self-register — PIN is stored hashed (SHA-256), never plain text
    match /instructors/{instructorId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Anonymous student feedback (Firestore only — no email addresses stored; host reviews in console / export)
    match /dashboardFeedback/{docId} {
      allow read: if false;
      allow create: if request.resource.data.keys().hasOnly(['subject', 'body', 'sessionCode', 'submittedAtMs'])
        && request.resource.data.subject is string
        && request.resource.data.body is string
        && request.resource.data.sessionCode is string
        && request.resource.data.submittedAtMs is int
        && request.resource.data.subject.size() > 0
        && request.resource.data.subject.size() <= 500
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 12000
        && request.resource.data.sessionCode.size() <= 40;
      allow update, delete: if false;
    }

    // Sessions (instructor creates/updates session info) and questions
    match /sessions/{sessionId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
      match /questions/{questionId} {
        allow read: if true;
        allow create: if true;
        // Updates keep authorId unchanged (votes, answers, status, student text edits).
        allow update: if resource.data.authorId == request.resource.data.authorId;
        // Instructors delete from the dashboard; without Firebase Auth this cannot be restricted to “only instructors”.
        allow delete: if true;
      }
    }
  }
}
